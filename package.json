{
  "name": "nagori",
  "private": true,
  "description": "Local-first, AI-assisted clipboard manager.",
  "license": "MIT",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "pnpm --filter @nagori/desktop dev",
    "build": "pnpm --filter @nagori/desktop build",
    "preview": "pnpm --filter @nagori/desktop preview",
    "check": "pnpm -r --parallel run check",
    "lint": "pnpm -r --parallel run lint",
    "fmt": "pnpm -r --parallel run fmt",
    "fmt:check": "pnpm -r --parallel run fmt:check",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r --parallel run test"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.14.1",
      "onFail": "download"
    }
  }
}
