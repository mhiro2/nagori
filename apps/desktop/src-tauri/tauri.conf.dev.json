{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "app": {
    "security": {
      "csp": {
        "default-src": "'self'",
        "img-src": ["'self'", "asset:", "data:", "https://asset.localhost"],
        "font-src": ["'self'", "data:"],
        "style-src": ["'self'", "'unsafe-inline'"],
        "script-src": ["'self'", "'wasm-unsafe-eval'"],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "ws://localhost:1420",
          "http://localhost:1420"
        ],
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'"
      }
    }
  }
}
